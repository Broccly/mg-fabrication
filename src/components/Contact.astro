---
---
<section id="contact" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 text-brand-orange text-sm font-semibold tracking-widest uppercase mb-4">
        <span class="w-8 h-px bg-brand-orange"></span>
        Get In Touch
        <span class="w-8 h-px bg-brand-orange"></span>
      </div>
      <h2 class="font-heading font-bold text-4xl sm:text-5xl text-white mb-4">Ready to Start Your Project?</h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg">
        Call us, WhatsApp us, or drop by. We're here Monday to Saturday, 8 AM to 7 PM.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Contact info -->
      <div class="space-y-6">
        <!-- Phone -->
        <div class="bg-brand-card border border-brand-border rounded-xl p-6 flex items-start gap-5 hover:border-brand-orange/40 transition-colors group">
          <div class="bg-brand-orange/10 text-brand-orange p-3 rounded-lg group-hover:bg-brand-orange group-hover:text-white transition-all flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-widest mb-1 font-semibold">Phone</div>
            <a href="tel:+917904783781" class="text-white text-xl font-bold hover:text-brand-orange transition-colors">+91 79047 83781</a>
            <p class="text-gray-500 text-sm mt-1">Mon–Sat, 8:00 AM – 7:00 PM</p>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="bg-brand-card border border-brand-border rounded-xl p-6 flex items-start gap-5 hover:border-green-500/40 transition-colors group">
          <div class="bg-green-500/10 text-green-500 p-3 rounded-lg group-hover:bg-green-500 group-hover:text-white transition-all flex-shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.848L.057 23.5l5.797-1.517A11.939 11.939 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.645-.52-5.148-1.42l-.369-.219-3.441.902.918-3.352-.24-.385A9.95 9.95 0 012 12c0-5.514 4.486-10 10-10s10 4.486 10 10-4.486 10-10 10z"/></svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-widest mb-1 font-semibold">WhatsApp</div>
            <a href="https://wa.me/917904783781?text=Hello%20MG%20Fabrication%20Works%2C%20I%20need%20a%20quote%20for%20fabrication%20work." target="_blank" class="text-white text-xl font-bold hover:text-green-500 transition-colors">Chat with Us</a>
            <p class="text-gray-500 text-sm mt-1">Quick response guaranteed</p>
          </div>
        </div>

        <!-- Email -->
        <div class="bg-brand-card border border-brand-border rounded-xl p-6 flex items-start gap-5 hover:border-brand-orange/40 transition-colors group">
          <div class="bg-brand-orange/10 text-brand-orange p-3 rounded-lg group-hover:bg-brand-orange group-hover:text-white transition-all flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-widest mb-1 font-semibold">Email</div>
            <a href="mailto:mgkannan1976@gmail.com" class="text-white text-xl font-bold hover:text-brand-orange transition-colors break-all">mgkannan1976@gmail.com</a>
            <p class="text-gray-500 text-sm mt-1">We reply within 24 hours</p>
          </div>
        </div>

        <!-- Address -->
        <div class="bg-brand-card border border-brand-border rounded-xl p-6 flex items-start gap-5 hover:border-brand-orange/40 transition-colors group">
          <div class="bg-brand-orange/10 text-brand-orange p-3 rounded-lg group-hover:bg-brand-orange group-hover:text-white transition-all flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-widest mb-1 font-semibold">Address</div>
            <p class="text-white font-bold text-lg leading-snug">MG Fabrication Works</p>
            <p class="text-gray-400 text-sm mt-1">No. 1, Periyandavar 1st Cross Street,<br />Oragadam, Ambattur,<br />Chennai – 600 053, Tamil Nadu</p>
            <a href="https://share.google/I01ggSuGUezxMAvvR" target="_blank" class="inline-flex items-center gap-1 text-brand-orange text-xs mt-2 hover:underline font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              View on Google Maps
            </a>
          </div>
        </div>

        <!-- CTA -->
        <a href="tel:+917904783781" class="flex items-center justify-center gap-3 w-full bg-brand-orange hover:bg-orange-600 text-white font-heading font-bold text-lg py-4 rounded-xl transition-all duration-200 shadow-lg shadow-orange-500/20 hover:shadow-orange-500/40 uppercase tracking-wide">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Now — Get a Free Quote
        </a>
      </div>

      <!-- Google Maps -->
      <div class="rounded-xl overflow-hidden border border-brand-border shadow-2xl h-full min-h-[500px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3886.3730369977327!2d80.1452!3d13.1144!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a5265ea4f7d3361%3A0x6e61a70b6863d433!2sAmbattur%20Industrial%20Estate%2C%20Chennai%2C%20Tamil%20Nadu!5e0!3m2!1sen!2sin!4v1719000000000!5m2!1sen!2sin"
          width="100%"
          height="100%"
          style="border:0; min-height: 500px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="MG Fabrication Works Location"
        ></iframe>
      </div>
    </div>
  </div>
</section>
