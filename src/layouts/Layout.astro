---
interface Props {
  title?: string;
}
const { title = 'MG Fabrication Works — Chennai' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="MG Fabrication Works — Chennai's trusted partner for metal roofing, plumbing, and welding fabrication services. Quality craftsmanship, on-time delivery." />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/logo-cropped.png" />
</head>
<body class="bg-brand-dark text-gray-100 font-body antialiased">
  <slot />
</body>
</html>
